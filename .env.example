APP_NAME=Dyslexia AI MVP
ENV=dev
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=*

DB_PATH=./data/app.db
DEVICE_ID_SALT=replace-this-with-a-strong-secret

ENABLE_LANGGRAPH_CHECKPOINT=false
CHECKPOINT_DB_PATH=./data/checkpoint.db

PROCESSING_TIMEOUT_SEC=90

# Unified model configuration (OpenAI-compatible Chat Completions API, Zhipu)
MODEL_API_BASE=https://open.bigmodel.cn/api/paas/v4
MODEL_API_KEY=
MODEL_TIMEOUT_SEC=60

INTENT_MODEL_NAME=glm-4-flash
INTENT_TEMPERATURE=0.2
INTENT_MAX_TOKENS=300

REPLY_MODEL_NAME=glm-4-flash
REPLY_TEMPERATURE=0.7
REPLY_MAX_TOKENS=900
REPLY_HISTORY_ROUNDS=3
