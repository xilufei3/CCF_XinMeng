APP_NAME=Dyslexia AI MVP
ENV=dev
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=*

DB_PATH=./data/app.db
DEVICE_ID_SALT=replace-this-with-a-strong-secret

ENABLE_LANGGRAPH_CHECKPOINT=false
CHECKPOINT_DB_PATH=./data/checkpoint.db

PROCESSING_TIMEOUT_SEC=90

# OpenAI-compatible endpoint (Zhipu)
MODEL_API_BASE=https://open.bigmodel.cn/api/paas/v4
MODEL_API_KEY=
MODEL_TIMEOUT_SEC=60

# Route model
ROUTE_MODEL_NAME=glm-4-flash
ROUTE_TEMPERATURE=0.3
ROUTE_MAX_TOKENS=512

# Response model
RESPONSE_MODEL_NAME=glm-4-flash
RESPONSE_TEMPERATURE=0.7
RESPONSE_MAX_TOKENS=4096

# Chat history
CHAT_HISTORY_ROUNDS=5

# Report session
# local: read reports from REPORT_LOCAL_DIR
# api: fetch reports from REPORT_API_URL_TEMPLATE
REPORT_SOURCE=local
REPORT_LOCAL_DIR=./data/reports/raw
# Example: http://127.0.0.1:9000/reports/{report_id}
REPORT_API_URL_TEMPLATE=
REPORT_API_TIMEOUT_SEC=10

# RAG
RETRIEVAL_ENABLED=true
RETRIEVAL_TOP_K=3
COLLECTION_NAME=xingmeng_docs
CHROMA_PERSIST_DIR=./chroma_db

# Zhipu embedding model
EMBEDDING_MODEL_NAME=embedding-3

PROMPT_VERSION=v1.1
